---
// src/pages/index.astro
import Base from '../layouts/Base.astro';
import StatsStrip from '../components/StatsStrip.astro';
import Term from '../components/Term.astro';
import { getPrepared } from '../prepare/prepare';
import { href } from '../lib/url';

const p = await getPrepared();
---
<Base
  title="Toronto Bids Archive"
  description="A citable public archive of City of Toronto procurement: solicitations, awards, bids, non-competitive contracts, council decisions, and suppliers."
>
  <p class="lede">
    A public record of how the City of Toronto buys goods and services — who bid, who won,
    and for how much. It's a research archive with stable, citable URLs and an honest
    account of the data's limits, built for journalists and researchers but open to anyone.
  </p>
  <p>
    It covers competitive <Term id="solicitation">solicitations</Term>,
    <Term id="award">awards</Term>, <Term id="bid">bids</Term> (including losing bidders),
    <Term id="non-competitive">non-competitive contracts</Term>, council decisions, and
    suppliers. Documents are indexed thoroughly; where the City hosts a file publicly, we
    link out to it.
  </p>
  <form action={href('/search/')} method="get" role="search" class="my-4">
    <input
      type="search"
      name="q"
      placeholder="Search titles, suppliers, document numbers, filenames…"
      class="border px-2 py-1 w-96 max-w-full"
    />
    <button type="submit" class="border px-3 py-1">Search</button>
  </form>
  <section class="start-here">
    <h2>Start here</h2>
    <p>New to City contracting? These questions lead to the most revealing views:</p>
    <ul>
      <li>
        <a href={href('/suppliers/?sort=a.desc')}>Which companies have won the most City money?</a>
      </li>
      <li>
        <a href={href('/noncompetitive/?sort=a.desc')}>Which large contracts skipped open
        competition — and what reasons did the City give?</a>
      </li>
      <li>
        <a href={href('/solicitations/?sole=yes')}>Which solicitations drew only a single bidder?</a>
      </li>
    </ul>
    <p>Unsure what a word means? Start with the <a href={href('/glossary/')}>glossary</a>.</p>
  </section>

  <StatsStrip headline={p.headline} />
  <nav class="my-4">
    <ul>
      <li><a href={href('/solicitations/')}>Browse solicitations</a></li>
      <li><a href={href('/noncompetitive/')}>Non-competitive contracts</a></li>
      <li><a href={href('/calls/')}>Composite award calls (2009–2012)</a></li>
      <li><a href={href('/council/')}>Council items</a></li>
      <li><a href={href('/suppliers/')}>Suppliers</a></li>
      <li><a href={href('/buyers/')}>Buyers (agencies &amp; corporations)</a></li>
      <li><a href={href('/capital-projects/')}>Capital project pipeline (City forecast, not open tenders)</a></li>
      <li><a href={href('/suspended-firms/')}>Suspended firms</a></li>
      <li><a href={href('/data/')}>Downloads &amp; in-browser SQL</a></li>
    </ul>
  </nav>

</Base>
