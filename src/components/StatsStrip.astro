---
// src/components/StatsStrip.astro — labeled headline stats (City-only, numeric-tier sums).
import type { Headline } from '../prepare/types';
import { formatCAD, IMPLAUSIBLE_AWARD_THRESHOLD } from '../prepare/amounts';

interface Props { headline: Headline }
const { headline } = Astro.props;
const outliers = headline.outlierAwardCount;
---
<dl class="stats-strip">
  <div><dt>Solicitations</dt><dd>{headline.solicitations.toLocaleString('en-CA')}</dd></div>
  <div><dt>Awarded (machine-parseable)</dt><dd>{formatCAD(headline.awardedTotal.total)}</dd></div>
  {outliers > 0 && (
    <div>
      <dt>Awarded, excl. {outliers} over {formatCAD(IMPLAUSIBLE_AWARD_THRESHOLD)}</dt>
      <dd>{formatCAD(headline.awardedTotalTrimmed.total)}</dd>
    </div>
  )}
  <div><dt>Non-competitive (machine-parseable)</dt><dd>{formatCAD(headline.noncompetitiveTotal.total)}</dd></div>
  <div><dt>Last recorded as Open</dt><dd>{headline.openCount.toLocaleString('en-CA')}</dd></div>
  <div><dt>Bids on record</dt><dd>{headline.bidCount.toLocaleString('en-CA')}</dd></div>
  <div><dt>Suppliers</dt><dd>{headline.supplierCount.toLocaleString('en-CA')}</dd></div>
</dl>
<p class="stats-caveat">
  City records only — agencies are listed separately. Dollar totals sum only
  machine-parseable amounts, so they undercount.{' '}
  {outliers > 0 && (
    <>The raw awarded figure also includes {outliers} implausible City-published
    award{outliers === 1 ? '' : 's'} over {formatCAD(IMPLAUSIBLE_AWARD_THRESHOLD)} (e.g. ~$9B to an
    individual); the figure beside it excludes {outliers === 1 ? 'it' : 'them'}.</>
  )}
</p>
